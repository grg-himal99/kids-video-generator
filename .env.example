# Google Gemini API key (FREE) — https://aistudio.google.com/app/apikey
# When set, stories are generated dynamically by Gemini for ANY topic.
# When unset, the generator falls back to the 24 built-in story templates.
GEMINI_API_KEY=your_gemini_key_here

# HuggingFace API token (FREE) — https://huggingface.co/settings/tokens
# Create a token with "Read" access.
HUGGINGFACE_API_KEY=hf_your_token_here
